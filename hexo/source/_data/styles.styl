// Archive banner (site-wide, injected via header.njk)
.archive-banner
  background-color rgba(23, 124, 176, 0.1)
  color #177CB0
  text-align center
  padding 10px 20px
  font-size 14px
  font-weight 500
  letter-spacing 0.3px

// Archive notice on the home page
.archive-home
  background-color rgba(23, 124, 176, 0.08)
  border 2px solid rgba(23, 124, 176, 0.4)
  border-radius 8px
  color #177CB0
  text-align center
  padding 20px 24px
  font-size 18px
  font-weight 600
  margin-bottom 28px
